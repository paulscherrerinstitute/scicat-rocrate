{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":enablePreCommit"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "reviewers": []
    }
  ],
  "ignorePaths": [],
  "customManagers": [
    {
      "description": "scicatlive",
      "customType": "regex",
      "fileMatch": [ "(^|/)[^/]+\\.java$" ],
      "matchStrings": [
        "renovate: datasource=(?<datasource>[^:]+?) depName=(?<depName>.+?)( versioning=(?<versioning>.+?))?( extractVersion=(?<extractVersion>.+?))?( registryUrl=(?<registryUrl>.+?))?\\s+(?:public|private|protected|static|final|String|\\s)*.+?\\s*=\\s*[\"'](?<currentValue>[^\"']+)[\"']\\s*;"
      ],
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver-coerced{{/if}}",
      "extractVersionTemplate": "{{#if extractVersion}}{{{extractVersion}}}{{else}}^v?(?<version>.+)${{/if}}"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [ "/Dockerfile.*$/" ],
      "matchStrings": [ "ARG SCICAT_CLI_VERSION=(?<currentValue>.*?)\\n" ],
      "depNameTemplate": "paulscherrerinstitute/scicat-cli",
      "datasourceTemplate": "github-releases"
    }
  ]
}
